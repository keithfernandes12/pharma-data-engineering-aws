# ===== Terraform =====
# State files can contain secrets and resource data — never commit them.
*.tfstate
*.tfstate.*
*.tfstate.backup
crash.log
crash.*.log
# Provider plugins / modules / lock caches
.terraform/
.terraform.lock.hcl
# Variable files that may hold secrets or account-specific values
*.tfvars
*.tfvars.json
!example.tfvars
# Terraform plan output
*.tfplan
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ===== AWS credentials / config =====
.aws/
aws.json
credentials
*.pem

# ===== Python (Glue scripts, local tooling) =====
.venv/
venv/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# ===== Power BI =====
*.tmp
~$*.pbix

# ===== Data build artifacts (raw CSVs in data/ ARE committed) =====
exports/
*.parquet

# ===== OS / editor =====
.DS_Store
Thumbs.db
.vscode/
.idea/
