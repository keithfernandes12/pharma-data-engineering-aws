{
  "name": "Pharma DE — Clean SaaS (validated palette, light)",
  "dataColors": [
    "#2a78d6",
    "#eb6834",
    "#1baf7a",
    "#eda100",
    "#e87ba4",
    "#008300",
    "#4a3aa7",
    "#e34948"
  ],
  "good": "#0ca30c",
  "neutral": "#fab219",
  "bad": "#d03b3b",
  "maximum": "#0d366b",
  "center": "#2a78d6",
  "minimum": "#cde2fb",
  "null": "#898781",
  "background": "#f9f9f7",
  "secondaryBackground": "#fcfcfb",
  "foreground": "#0b0b0b",
  "tableAccent": "#2a78d6",
  "textClasses": {
    "title":    { "fontFace": "Segoe UI Semibold", "color": "#0b0b0b", "fontSize": 14 },
    "label":    { "fontFace": "Segoe UI", "color": "#52514e", "fontSize": 10 },
    "callout":  { "fontFace": "Segoe UI", "color": "#0b0b0b", "fontSize": 32 }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [{ "show": true, "color": { "solid": { "color": "#fcfcfb" } }, "transparency": 0 }],
        "border": [{ "show": true, "color": { "solid": { "color": "#e1e0d9" } }, "radius": 12 }],
        "dropShadow": [{ "show": true, "color": { "solid": { "color": "#000000" } }, "position": "Outer", "preset": "Custom", "shadowSpread": 2, "shadowBlur": 12, "transparency": 92 }],
        "visualHeader": [{ "show": false }],
        "categoryAxis": [{ "gridlineShow": false, "labelColor": { "solid": { "color": "#898781" } }, "titleColor": { "solid": { "color": "#52514e" } } }],
        "valueAxis": [{ "gridlineColor": { "solid": { "color": "#e1e0d9" } }, "gridlineThickness": 1, "labelColor": { "solid": { "color": "#898781" } } }],
        "title": [{ "show": true, "fontColor": { "solid": { "color": "#0b0b0b" } }, "fontSize": 14, "fontFamily": "Segoe UI Semibold", "alignment": "left" }]
      }
    },
    "card": {
      "*": {
        "labels": [{ "color": { "solid": { "color": "#0b0b0b" } }, "fontSize": 28, "fontFamily": "Segoe UI Semibold" }],
        "categoryLabels": [{ "color": { "solid": { "color": "#898781" } }, "fontSize": 10 }]
      }
    },
    "page": {
      "*": {
        "background": [{ "color": { "solid": { "color": "#f9f9f7" } }, "transparency": 0 }]
      }
    }
  }
}
